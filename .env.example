# Home Assistant Configuration
# Your Home Assistant API URL (e.g., http://homeassistant.local:8123/api/services)
HA_URL=http://localhost:8123/api/services
# Your Long Lived Access Token (Create this in your profile on HA)
HA_TOKEN=your_long_lived_access_token_here

# Audio Settings (Optional Overrides)
# Set to '1' to prevent models from checking for updates online
# TRANSFORMERS_OFFLINE=1
# HF_HUB_OFFLINE=1

# Web UI Configuration
# FLASK_SECRET_KEY=your_secret_key_here
