{
  "commands": [
    {
      "comment": "================ 🏠 GENERIC APPLIANCE CONTROL (LOCATION AWARE) ================"
    },
    {
      "id": "LIGHT_ON",
      "type": "ha",
      "mode": "normal",
      "phrases": ["turn on the light", "lights on", "switch on the light", "it's too dark in here"],
      "strict_aliases": ["light on", "lights on"],
      "payload": { "domain": "light", "service": "turn_on", "entity": "context_aware" },
      "reply_template": "Lights on."
    },
    {
      "id": "LIGHT_OFF",
      "type": "ha",
      "mode": "normal",
      "phrases": ["turn off the light", "lights off", "switch off the light", "it's bright enough"],
