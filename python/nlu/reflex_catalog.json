      "strict_aliases": ["tv on", "tv off"],
      "payload": { "domain": "media_player", "service": "toggle", "entity": "context_aware" },
      "reply_template": "Updating media state."
    },

    {
      "comment": "================ 🤖 SYSTEM CORE (UNIVERSAL) ================"
    },
    {
      "id": "STOP",
      "type": "sys",
      "mode": "normal",
      "phrases": ["stop", "shut up", "cancel", "quiet", "terminate", "halt"],
      "strict_aliases": ["stop", "cancel", "silence"],
      "payload": { "action": "stop_audio" },
      "reply_template": "Stopped."
    },
    {
      "id": "CONFIRM_YES",
      "type": "sys",
      "mode": "normal",
      "phrases": ["yes", "yeah", "sure", "do it", "correct", "go ahead", "please"],
      "strict_aliases": ["yes", "ok", "yep"],
      "payload": { "action": "confirm_yes" },
      "reply_template": "Confirmed."
    },
    {
      "id": "CONFIRM_NO",
      "type": "sys",
      "mode": "normal",
      "phrases": ["no", "nope", "wrong", "don't", "nevermind", "abort"],
      "strict_aliases": ["no", "cancel"],
      "payload": { "action": "confirm_no" },
      "reply_template": "Cancelled."
    },

    {
      "comment": "================ 🔐 SUDO OPERATIONS (RESTRICTED) ================"
    },
    {
      "id": "SUDO_ACCESS",
      "type": "sys",
      "mode": "normal",
